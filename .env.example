# Resend API key (already issued to Progressly account)
RESEND_API_KEY=

# Where form submissions are delivered.
# Supports a single email OR a comma-separated list:
#   DESTINATION_EMAIL=ottawabah@gmail.com
#   DESTINATION_EMAIL=ottawabah@gmail.com,yahia@example.com
DESTINATION_EMAIL=ottawabah@gmail.com

# Optional: Google Apps Script web app URL for logging leads to a Google Sheet.
# If unset, leads still get emailed; sheet logging is just skipped.
SHEETS_WEBHOOK_URL=
